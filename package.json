{
  "name": "piyush-snapchat",
  "version": "1.0.0",
  "private": true,
  "description": "A premium Snapchat clone \u2014 Made by Piyush",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "cap:sync": "next build && npx cap sync android",
    "apk:debug": "npm run cap:sync && cd android && ./gradlew assembleDebug"
  },
  "dependencies": {
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@react-three/drei": "^9.114.3",
    "@react-three/fiber": "^8.17.10",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "emoji-mart": "^5.6.0",
    "framer-motion": "^11.11.9",
    "lucide-react": "^0.453.0",
    "next": "14.2.15",
    "qrcode.react": "^4.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.4",
    "three": "^0.169.0",
    "zustand": "^5.0.0",
    "@capacitor/core": "^6.1.2",
    "@capacitor/android": "^6.1.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.1",
    "@testing-library/react": "^16.0.1",
